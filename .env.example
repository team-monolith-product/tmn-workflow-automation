# AWS Athena Configuration (Phase 1 - Data Analysis Bot)
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=ap-northeast-2
# Note: ATHENA_DATABASE 환경 변수 없음
# AI가 Redash 쿼리를 분석하여 항상 명시적으로 데이터베이스를 지정합니다
ATHENA_OUTPUT_LOCATION=s3://your-bucket/athena-results/

# Redash Configuration (Phase 1 - Data Analysis Bot)
REDASH_API_KEY=your-redash-api-key
REDASH_BASE_URL=https://your-redash-instance.com

# GitHub Configuration
# GITHUB_TOKEN: PR/리뷰 조회 등 읽기 작업용 (repo:read, read:org)
