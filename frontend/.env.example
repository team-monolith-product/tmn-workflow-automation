# WA 어드민 프론트 빌드 환경변수 (VITE_*)
# admin-rails(Doorkeeper)로 로그인하고 WA FastAPI(api/edu-bid)를 호출한다.

VITE_AUTH_SERVER=https://admin-rails.codle.io
VITE_CLIENT_ID=                 # WA 어드민용 Doorkeeper application client_id (admin-rails 에서 발급)
VITE_API_BASE=                  # 비우면 동일 오리진(FastAPI가 /admin 으로 SPA 서빙 시)
